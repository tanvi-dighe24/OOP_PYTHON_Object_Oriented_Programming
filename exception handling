        ----program---


    except Exception as variablename:


        ---solution--




try:


    a=int(input('enter a number:'))


    b=int(input('enter a number2:'))


    print(a/b)


except Exception:


    print('handling  exception')




def sam():


    try:


        a=int(input('enter a number:'))


        b=int(input('enter a number2:'))


        print(a/b)


    except Exception as n:


        print('handling  exception')


        print(n)


        sam()



sam()




